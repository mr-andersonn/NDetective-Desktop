<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NDetective.App"
             xmlns:local="using:NDetective"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://NDetective/Assets/icons.axaml" />
    </Application.Styles>
    
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/NDetectiveIcon.ico"
                      ToolTipText="NDetective"
                      Clicked="TrayClicked">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Open" 
                                        Click="OpenApp"/>
                        <NativeMenuItem Header="Hide" 
                                        Click="HideApp"/>
                        <NativeMenuItem Header="Exit" 
                                        Click="CloseApp"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>