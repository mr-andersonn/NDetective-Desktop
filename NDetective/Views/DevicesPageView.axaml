<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:NDetective.Views"
             xmlns:viewModels="clr-namespace:NDetective.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="NDetective.Views.DevicesPageView"
             x:DataType="viewModels:DevicesPageViewModel">
    
    <Grid Margin="16" RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="Devices" 
                   FontSize="20" FontWeight="Bold"
                   Margin="0, 10"/>
        
        <Grid Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray"
                                BorderThickness="0,0,0,1"
                                Margin="0,4">
                            <Grid ColumnDefinitions="*,Auto,Auto,*" 
                                  Margin="0, 5">

                                <TextBlock Grid.Column="0"
                                           Text="Name" 
                                           FontSize="18"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Margin="0 0 70 0 "
                                           Text="{Binding Ip}" 
                                           FontSize="15" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Mac}" 
                                           FontSize="15" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Edit"
                                        Width="100"
                                        HorizontalContentAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Stretch"
                                        Click="OpenEditDeviceWindow"/> 
                            </Grid>
                        </Border>


                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <Button Content="Add Device"
                    Width="100"
                    Height="40"
                    VerticalContentAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"/>
        </Grid>
        

    </Grid>
    
    
    
</UserControl>
