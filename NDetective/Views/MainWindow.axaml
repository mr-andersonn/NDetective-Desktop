<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NDetective.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        Width="1200" Height="700"
        WindowStartupLocation="CenterScreen"
        x:Class="NDetective.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/NDetectiveIcon.png"
        Title="NDetective"
        Classes="MainWindow">
    
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>
    
    <Window.Styles>
        <StyleInclude Source="avares://NDetective/Styles/Styles.axaml"/>
    </Window.Styles>
    


    <SplitView IsPaneOpen="{Binding IsPaneOpen}"
               OpenPaneLength="200"
               CompactPaneLength="50"
               DisplayMode="CompactInline"
               Background="#1e1e1e">
        
        <!-- This is the menu. -->
        <SplitView.Pane>
            <StackPanel Spacing="10"
                        Margin="5">
                <Button Command="{Binding HideOpenMenuCommand}"
                        Background="#1f1f1f">
                    <PathIcon Data="{Binding CurrentPaneIcon}"></PathIcon>
                </Button>
                
                <!-- Structure for the list of items in the menu. It gets the items from the ListItemTemplate-->
                <ListBox ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedListItem}"
                        Background="#1f1f1f"
                         Foreground="White">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ListItemTemplate}">
                            <StackPanel Spacing="15" Orientation="Horizontal">
                                <PathIcon Data="{Binding ListItemIcon}"/>
                                <TextBlock Text="{Binding Label}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                
            </StackPanel>
        </SplitView.Pane>
        
        
        <!-- This is the main window that changes -->
        <SplitView.Content>
            <Border CornerRadius="12 0 0 0"
                    Background="#1d1d1d">
                <TransitioningContentControl Content="{Binding CurrentPage}" />
            </Border>
        </SplitView.Content>
    </SplitView>
    
    

</Window>
